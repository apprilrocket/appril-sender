# appril-sender — variables de entorno (mismas en ambas Lambdas).
# Copia a .env y rellena con los valores reales.
# Los valores reales están en la config de las Lambdas en AWS; para volcarlos:
#   aws lambda get-function-configuration --function-name appril-crm-sender \
#     --region us-east-1 --query 'Environment.Variables'

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AWS SES (email)
# Remitente unificado: todo Appril desde hola@appril.co (envía y recibe).
# Reply-To = mismo dominio que From (NO usar todoc.co salvo que se envíe desde ahí).
SES_FROM_EMAIL=hola@appril.co
SES_REPLY_TO=hola@appril.co
SES_CONFIGURATION_SET=appril-crm

# WhatsApp Cloud API (Meta)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_API_VERSION=v21.0
WA_APP_SECRET=
WA_VERIFY_TOKEN=
WA_WABA_ID=

# Tuning del sender
BATCH_SIZE=50
MAX_ATTEMPTS=3

# Región (en Lambda viene auto; para correr local)
AWS_REGION=us-east-1
